@startuml
left to right direction

actor User

rectangle "콘서트 예약 시스템" {

    package "잔액 관리" {
        User --> (잔액 충전)
        User --> (잔액 조회)
    }

    package "콘서트 조회" {
        User --> (콘서트 목록 조회)
        User --> (콘서트 회차 조회)
        User --> (콘서트 좌석 조회)
    }

    package "대기열 관리" {
        (콘서트 좌석 조회) ..> (대기열 토큰 발급) : <<include>>
        User --> (대기열 조회)
    }

    package "예약 및 결제" {
        User --> (콘서트 좌석 예약)
        User --> (예약 좌석 조회)
        User --> (예약 취소)
        User --> (예약 좌석 결제)
        User --> (예약 좌석 환불)
    }
}
@enduml
